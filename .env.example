# Copie ce fichier en ".env" et remplis les vraies valeurs.
# Ne jamais committer le fichier ".env" dans Git (il contient des secrets).

PORT=4000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_moi
DB_NAME=equipe_rh

# Clé secrète utilisée pour signer les tokens de connexion.
# Génère une vraie valeur aléatoire avec : openssl rand -hex 32
JWT_SECRET=change_moi_avec_une_vraie_cle_aleatoire
